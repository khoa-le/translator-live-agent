# LiveKit server connection
LIVEKIT_URL=ws://localhost:7880
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=secret

# Provider API keys (at least one required)
GOOGLE_API_KEY=
OPENAI_API_KEY=

# Translation settings
SOURCE_LANGUAGE=Japanese
TARGET_LANGUAGE=Vietnamese
TRANSLATION_MODE=pipeline
# TRANSLATION_MODE options:
#   pipeline       — STT → LLM translate → TTS (most flexible, multi-provider)
#   realtime_gemini — Gemini Live API end-to-end (lowest latency)
#   realtime_openai — OpenAI Realtime API end-to-end
